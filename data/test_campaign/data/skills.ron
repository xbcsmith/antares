// skills.ron — Stable test fixture for the Antares skill system.
//
// These definitions are used exclusively by unit tests and integration tests.
// DO NOT load this file from campaigns/tutorial. Tests MUST reference this file.
//
// Covers all four SkillScalingMode variants so that tests can exercise each code path.
[
    // ── Exploration ──────────────────────────────────────────────────────────

    (
        id: "perception",
        name: "Perception",
        category: Exploration,
        description: "The ability to notice hidden objects, traps, and threats. Increases steadily with experience.",
        scaling: Linear(base: 0, per_level: 1),
        max_rank: 50,
        is_trainable: true,
    ),

    (
        id: "disarm_traps",
        name: "Disarm Traps",
        category: Exploration,
        description: "Skill at safely disarming mechanical and magical traps. Improves every two levels.",
        scaling: Step(base: 0, per_levels: 2, amount: 1),
        max_rank: 25,
        is_trainable: true,
    ),

    // ── Knowledge ────────────────────────────────────────────────────────────

    (
        id: "item_lore",
        name: "Item Lore",
        category: Knowledge,
        description: "Knowledge of magical and mundane items, enabling identification without a sage.",
        scaling: Linear(base: 0, per_level: 1),
        max_rank: 50,
        is_trainable: true,
    ),

    // ── Social ───────────────────────────────────────────────────────────────

    (
        id: "diplomacy",
        name: "Diplomacy",
        category: Social,
        description: "The art of negotiation, persuasion, and peaceful conflict resolution. Must be trained.",
        scaling: Flat,
        max_rank: 30,
        is_trainable: true,
    ),

    // ── Utility ──────────────────────────────────────────────────────────────

    (
        id: "athletics",
        name: "Athletics",
        category: Utility,
        description: "Physical fitness covering climbing, swimming, and jumping. Base 1, grows every 3 levels.",
        scaling: Step(base: 1, per_levels: 3, amount: 1),
        max_rank: 20,
        is_trainable: true,
    ),

    // ── Table scaling example (Knowledge) ────────────────────────────────────
    // Included so tests can exercise the Table variant with real fixture data.

    (
        id: "arcane_lore",
        name: "Arcane Lore",
        category: Knowledge,
        description: "Understanding of arcane forces, spells, and magical creatures. Grows in discrete tiers.",
        scaling: Table(ranks_by_level: [0, 0, 1, 1, 2, 2, 3, 3, 4, 4, 5, 6, 7, 8, 9, 10]),
        max_rank: 40,
        is_trainable: true,
    ),

    // ── Combat ───────────────────────────────────────────────────────────────────────

    (
        id: "leadership",
        name: "Leadership",
        category: Combat,
        description: "Commanding presence that bolsters allies in battle.",
        scaling: Flat,
        max_rank: 20,
        is_trainable: true,
    ),

    // ── Knowledge (second) ───────────────────────────────────────────────────────────

    (
        id: "divine_lore",
        name: "Divine Lore",
        category: Knowledge,
        description: "Knowledge of divine forces, holy creatures, and sacred sites.",
        scaling: Table(ranks_by_level: [0, 0, 1, 1, 2, 2, 3, 3, 4, 4, 5, 6, 7, 8, 9, 10]),
        max_rank: 40,
        is_trainable: true,
    ),

    // ── Utility (second) ───────────────────────────────────────────────────────────────────

    (
        id: "stealth",
        name: "Stealth",
        category: Utility,
        description: "Moving silently and remaining unseen.",
        scaling: Step(base: 0, per_levels: 2, amount: 1),
        max_rank: 30,
        is_trainable: true,
    ),

    // ── Exploration (second) ─────────────────────────────────────────────────────────────

    (
        id: "tracking",
        name: "Tracking",
        category: Exploration,
        description: "Reading trails and signs to locate quarry.",
        scaling: Linear(base: 0, per_level: 1),
        max_rank: 30,
        is_trainable: true,
    ),
]
